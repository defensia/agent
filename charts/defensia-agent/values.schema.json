{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "token": {
      "type": "string",
      "description": "Install token from https://defensia.cloud/dashboard"
    },
    "existingSecret": {
      "type": "string",
      "description": "Name of an existing Secret containing the token (key must be 'token')"
    },
    "serverUrl": {
      "type": "string",
      "description": "Defensia panel URL",
      "default": "https://defensia.cloud"
    },
    "agentName": {
      "type": "string",
      "description": "Agent name override (default: node hostname)"
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string",
          "default": "ghcr.io/defensia/agent"
        },
        "tag": {
          "type": "string",
          "description": "Defaults to appVersion"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["IfNotPresent", "Always", "Never"],
          "default": "IfNotPresent"
        }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "limits": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        },
        "requests": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        }
      }
    },
    "tolerations": {
      "type": "array",
      "description": "Pod tolerations — default tolerates all taints"
    },
    "nodeSelector": {
      "type": "object"
    },
    "affinity": {
      "type": "object"
    },
    "hostPaths": {
      "type": "object",
      "properties": {
        "log": {
          "type": "string",
          "default": "/var/log"
        },
        "dockerSocket": {
          "type": "string",
          "default": "/var/run/docker.sock"
        }
      }
    },
    "extraEnv": {
      "type": "array",
      "description": "Extra environment variables",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "value": { "type": "string" }
        },
        "required": ["name", "value"]
      }
    }
  }
}
